  "components": {
    "schemas": {
      "APIResponse": {
        "properties": {
          "success": {
            "type": "boolean",
            "title": "Success"
          },
          "code": {
            "type": "integer",
            "title": "Code"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "data": {
            "anyOf": [
              {
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Data"
          },
          "timestamp": {
            "type": "string",
            "title": "Timestamp"
          }
        },
        "type": "object",
        "required": [
          "success",
          "code",
          "message"
        ],
        "title": "APIResponse",
        "description": "API响应"
      },
      "DetectionRequest": {
        "properties": {
          "image_data": {
            "type": "string",
            "title": "Image Data",
            "description": "Base64编码的图像数据"
          },
          "image_format": {
            "type": "string",
            "title": "Image Format",
            "description": "图像格式",
            "default": "png"
          }
        },
        "type": "object",
        "required": [
          "image_data"
        ],
        "title": "DetectionRequest",
        "description": "检测请求"
      },
      "DeviceRegistration": {
        "properties": {
          "device_id": {
            "type": "string",
            "title": "Device Id"
          },
          "device_info": {
            "type": "object",
            "title": "Device Info"
          },
          "capabilities": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Capabilities"
          }
        },
        "type": "object",
        "required": [
          "device_id",
          "device_info",
          "capabilities"
        ],
        "title": "DeviceRegistration",
        "description": "设备注册"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LocationUpdate": {
        "properties": {
          "latitude": {
            "type": "number",
            "title": "Latitude",
            "description": "纬度"
          },
          "longitude": {
            "type": "number",
            "title": "Longitude",
            "description": "经度"
          },
          "accuracy": {
            "type": "number",
            "title": "Accuracy",
            "description": "精度（米）",
            "default": 5.0
          },
          "timestamp": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Timestamp",
            "description": "时间戳"
          }
        },
        "type": "object",
        "required": [
          "latitude",
          "longitude"
        ],
        "title": "LocationUpdate",
        "description": "位置更新"
      },
      "RouteRequest": {
        "properties": {
          "start_latitude": {
            "type": "number",
            "title": "Start Latitude",
            "description": "起点纬度"
          },
          "start_longitude": {
            "type": "number",
            "title": "Start Longitude",
            "description": "起点经度"
          },
          "end_latitude": {
            "type": "number",
            "title": "End Latitude",
            "description": "终点纬度"
          },
          "end_longitude": {
            "type": "number",
            "title": "End Longitude",
            "description": "终点经度"
          },
          "navigation_mode": {
            "type": "string",
            "title": "Navigation Mode",
            "description": "导航模式",
            "default": "walking"
          }
        },
        "type": "object",
        "required": [
          "start_latitude",
          "start_longitude",
          "end_latitude",
          "end_longitude"
        ],
        "title": "RouteRequest",
        "description": "路线规划请求"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "VoiceRequest": {
        "properties": {
          "text": {
            "type": "string",
            "title": "Text",
            "description": "要合成的文本"
          },
          "voice_type": {
            "type": "string",
            "title": "Voice Type",
            "description": "语音类型",
            "default": "default"
          },
          "speed": {
            "type": "number",
            "title": "Speed",
            "description": "语速",
            "default": 1.0
          },
          "volume": {
            "type": "number",
            "title": "Volume",
            "description": "音量",
            "default": 1.0
          }
        },
        "type": "object",
        "required": [
          "text"
        ],
        "title": "VoiceRequest",
        "description": "语音请求"
      }
    }
  }
